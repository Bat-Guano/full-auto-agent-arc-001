# Copy this file to .env.agent and fill in real values.
#
# cp .env.agent.example .env.agent

DEPLOY_STAGING=false

# Safer first run:
#   acceptEdits
# More automated:
#   auto
# Disposable VM only:
#   bypassPermissions
CLAUDE_PERMISSION_MODE=acceptEdits

MAX_REPAIRS=2
AGENT_BRANCH=agent/sequential-run
REMOTE_NAME=origin

PORT=3000
LOCAL_HEALTH_PATH=/

SERVER_HOST=
SERVER_USER=
APP_DIR=
APP_NAME=my-app
STAGING_URL=
STAGING_HEALTH_PATH=/api/health
